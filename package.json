{
  "name": "bastion",
  "private": true,
  "version": "1.0.0",
  "description": "Build tooling for OverPy workshop outputs",
  "packageManager": "pnpm@10.6.3",
  "scripts": {
    "build:main": "overpy compile -i src/main.opy -o build/main.ow -l en-US",
    "build:dev": "overpy compile -i src/devMain.opy -o build/devMain.ow -l en-US",
    "build:main:en": "overpy compile -i src/main.opy -o build/main.en-US.ow -l en-US",
    "build:dev:en": "overpy compile -i src/devMain.opy -o build/devMain.en-US.ow -l en-US",
    "build:main:zh": "overpy compile -i src/main.opy -o build/main.zh-CN.ow -l zh-CN",
    "build:dev:zh": "overpy compile -i src/devMain.opy -o build/devMain.zh-CN.ow -l zh-CN",
    "generate:title-query-data": "node tools/generate-title-query-data.mjs",
    "dev:title-query": "pnpm run generate:title-query-data && vite --config web/title-query/vite.config.mjs",
    "build:title-query": "pnpm run generate:title-query-data && vite build --config web/title-query/vite.config.mjs",
    "build:pages": "pnpm run build:title-query",
    "test:title-query-data": "node --test tools/generate-title-query-data.test.mjs",
    "build:release": "pnpm run build:main:en && pnpm run build:dev:en && pnpm run build:main:zh && pnpm run build:dev:zh",
    "build": "pnpm run build:main && pnpm run build:dev"
  },
  "dependencies": {
    "overpy": "^9.4.24",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "vite": "^6.2.2"
  }
}
